#OMADA_ADOPT_TRY_V2="true"

# ------------------------------------------------------------
# Omada Hotspot Operator (REQUIRED for External Portal v2)
# ------------------------------------------------------------
# After a customer pays, SSDomada calls Omada's external-portal API
# (POST /{omadacId}/api/v2/hotspot/extPortal/auth) to release the captive
# portal hold. Without this, Wi-Fi stays on "Sign in to network".
#
# Create a Hotspot Operator in:
#   Omada Controller → Site → Settings → Authentication → Hotspot → Operators
# Use a dedicated account (do NOT reuse the controller admin login).
OMADA_HOTSPOT_USERNAME=""
OMADA_HOTSPOT_PASSWORD=""
# Set to "true" only for self-signed dev controllers — disables TLS verification.
#OMADA_HOTSPOT_TLS_INSECURE="false"

# Redis (optional — defaults to redis://localhost:6379; in-memory fallback if unreachable)
#REDIS_URL="redis://localhost:6379"

# ============================================================
# Snippe Payment Gateway  (API version 2026-01-25)
# Docs: https://docs.snippe.sh/docs/2026-01-25
# ============================================================
SNIPPE_BASE_URL="https://api.snippe.sh"
# Bearer API key — Dashboard → Settings → API Keys
SNIPPE_API_KEY="snp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Signing key for webhook signature verification — Dashboard → Settings → Webhook Secret
# (or POST /api/v1/settings/webhook-secret/regenerate)
SNIPPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Legacy aliases (kept so older deploys do not break — prefer SNIPPE_BASE_URL above)
# SNIPPE_API_URL="https://api.snippe.sh"

# FreeRADIUS
RADIUS_SECRET="SSDomada2026SecureR@dius"
RADIUS_NAS_IP="107.152.36.210"

# Omada "Pre-Authentication Access" — set in Controller UI (Portal → Access Control); SSDomada does not push this via API yet.
# Hostnames to allow before login: keep this as a small walled garden for your app,
# Omada Controller if guest ACLs block it, and browser checkout hosts.
# Do NOT normally allow OS probe hosts such as connectivitycheck.gstatic.com or
# www.msftconnecttest.com; they can make phones/laptops skip the captive portal.
# Evidence + full list: docs/captive-preauth-allowlist.md
#
# Example CSV (for your runbook only — uncomment if you use a script later):
OMADA_PREAUTH_REFERENCE_HOSTS="ssdomada.site,www.ssdomada.site,server.ssdomada.site,api.snippe.co.tz"

docker cp /path/to/backup/captive/. ssdomada-app:/app/public/uploads/captive/
